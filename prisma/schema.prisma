generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role{
  CUSTOMER
  PROMOTER
  ADMIN
}

model app_config {
  config_key   String @id @db.VarChar(120)
  config_value String @db.Text
}

model event_ticket_types {
  id              Int     @id @default(autoincrement())
  event_id        Int
  name            String  @db.VarChar(120)
  badge           String? @db.VarChar(80)
  badge_color     String? @db.VarChar(30)
  description     String? @db.Text
  bullet1         String? @db.VarChar(160)
  bullet2         String? @db.VarChar(160)
  bullet3         String? @db.VarChar(160)
  price           Int
  stock_remaining Int     @default(0)
  max_per_order   Int     @default(4)
  sort_order      Int
  events          events  @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_ticket_types_event")

  @@index([event_id], map: "fk_ticket_types_event")
}

model events {
  id                 Int                  @id @default(autoincrement())
  user_id            Int?
  title              String               @db.VarChar(200)
  lineup             String?              @db.VarChar(200)
  venue              String               @db.VarChar(120)
  city               String               @db.VarChar(120)
  date_label         String               @db.VarChar(40)
  show_time          String?              @db.VarChar(80)
  price              String?              @db.VarChar(40)
  image              String?              @db.Text
  detail_image       String?              @db.Text
  venue_layout       String?              @db.VarChar(160)
  description        String?              @db.Text
  source_url         String?              @db.Text
  tag1               String?              @db.VarChar(50)
  tag2               String?              @db.VarChar(50)
  button             String?              @db.VarChar(50)
  is_featured        Boolean              @default(false)
  is_limited         Boolean              @default(false)
  remaining_seats    Int                  @default(0)
  sort_order         Int                  @default(0)
  is_favorite        Boolean              @default(false)
  event_ticket_types event_ticket_types[]
  users              users?               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_events_user")

  @@index([user_id], map: "fk_events_user")
}

model notifications {
  id         Int    @id @default(autoincrement())
  title      String @db.VarChar(200)
  subtitle   String @db.Text
  sort_order Int
}

model tickets {
  id            Int    @id @default(autoincrement())
  user_id       Int?
  title         String @db.VarChar(200)
  image         String @db.Text
  date_label    String @db.VarChar(40)
  time_label    String @db.VarChar(40)
  venue         String @db.VarChar(120)
  section       String @db.VarChar(40)
  row_label     String @db.VarChar(40)
  seat_label    String @db.VarChar(40)
  qr_data       String @db.VarChar(255)
  ticket_type   String @db.VarChar(100)
  ticket_status String @default("UPCOMING") @db.VarChar(50)
  sort_order    Int
  users         users? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_tickets_user")

  @@index([user_id], map: "fk_tickets_user")
}

model user_favorites {
  id            Int                          @id @default(autoincrement())
  user_id       Int
  favorite_type user_favorites_favorite_type
  item_id       Int
  created_at    DateTime                     @default(now()) @db.DateTime(0)
  users         users                        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_user_favorites_user")

  @@unique([user_id, favorite_type, item_id], map: "uq_user_favorites_item")
}

model users {
  id                    Int              @id @default(autoincrement())
  username              String           @unique(map: "username") @db.VarChar(120)
  name                  String           @db.VarChar(120)
  email                 String           @unique(map: "email") @db.VarChar(255)
  phone                 String?          @db.VarChar(30)
  password_hash         String           @db.VarChar(255)
  bio                   String?          @db.Text
  location              String?          @db.VarChar(120)
  avatar_url            String?          @db.Text
  followers_count       Int              @default(0)
  events_count          Int              @default(0)
  upcoming_events_count Int              @default(0)
  genre                 String?          @db.VarChar(120)
  description           String?          @db.Text
  role                  String           @default("user") @db.VarChar(50)
  is_verified           Boolean          @default(false)
  sort_order            Int              @default(0)
  created_at            DateTime         @default(now()) @db.DateTime(0)
  events                events[]
  tickets               tickets[]
  user_favorites        user_favorites[]
}

enum user_favorites_favorite_type {
  event
  artist
}
